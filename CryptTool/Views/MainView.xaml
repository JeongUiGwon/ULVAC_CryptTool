<Window x:Class="CryptTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CryptTool"
        xmlns:vm="clr-namespace:CryptTool.ViewModels"
        mc:Ignorable="d"
        Title="Crypt Tool" Height="500" Width="800">
    
    <Window.Resources>
        <Style x:Key="MenuItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd"
                                    Property="Background"
                                    Value="#FFE9EEF9"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"
                                    Property="Background"
                                    Value="#FFF3F5F8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Menu -->
        <Border Grid.Column="0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="10"
                           FontSize="16"
                           FontWeight="Bold"
                           Text="Menu"/>

                <ListBox Margin="3"
                         ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedItem}"
                         DisplayMemberPath="Title"
                         ItemContainerStyle="{StaticResource MenuItemStyle}"
                         BorderThickness="0"/>
            </DockPanel>
        </Border>

        <!-- Divider -->
        <GridSplitter Grid.Column="1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Background="#FFE1E1E1"
                  ResizeBehavior="PreviousAndNext"
                  ResizeDirection="Columns"
                  ShowsPreview="True"/>

        <!-- Right Content -->
        <Frame Grid.Column="2"
               Source="{Binding CurrentPageUri}"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
