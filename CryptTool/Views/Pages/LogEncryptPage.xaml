<Page x:Class="CryptTool.Views.Pages.LogEncryptPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CryptTool.Views.Pages"
      xmlns:vm="clr-namespace:CryptTool.ViewModels.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LogEncryptPage" Background="White">

    <Page.DataContext>
        <vm:LogEncryptViewModel/>
    </Page.DataContext>

    <Page.Resources>

        <!-- Row 강조 -->
        <Style TargetType="{x:Type ListViewItem}">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF3F5F8"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE9EEF9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 상태 색상 -->
        <Style x:Key="StatusTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FF444444"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FF222222"
                           Text="Log Encrypt / Decrypt"/>

                <!-- Folder selector -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Foreground="#FF333333"
                               Text="History Path :"/>

                    <TextBox Grid.Column="2"
                             Height="26"
                             VerticalContentAlignment="Center"
                             Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Grid.Column="3"
                            Content="Browse"
                            Width="60"
                            Margin="5,0"
                            Command="{Binding BrowseCommand}"/>

                    <Button Grid.Column="4"
                            Content="Refresh"
                            Width="60"
                            Command="{Binding RefreshCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Body -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Summary / Filter row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Foreground="#FF555555"
                               FontSize="13"
                               Text="{Binding SummaryText, Mode=OneWay}"/>
                </Grid>

                <!-- ListView -->
                <ListView Grid.Row="2"
                          ItemsSource="{Binding Files}"
                          SelectionMode="Extended"
                          BorderBrush="#FFE1E1E1"
                          BorderThickness="1">

                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" />

                            <GridViewColumn Header="Full Path" DisplayMemberBinding="{Binding FullName}" />

                            <GridViewColumn Header="Modified" DisplayMemberBinding="{Binding LastWriteTime}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Footer Buttons + Progress -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Progress / Current file -->
                <StackPanel Orientation="Vertical">
                    <TextBlock Foreground="#FF555555"
                               FontSize="13"
                               Text="{Binding CurrentWorkText, Mode=OneWay}"/>

                    <ProgressBar Height="10"
                                 Margin="0,8,0,0"
                                 Minimum="0"
                                 Maximum="{Binding ProgressMax, Mode=OneWay}"
                                 Value="{Binding ProgressValue, Mode=OneWay}"/>
                </StackPanel>

                <!-- Action Buttons -->
                <Button Grid.Column="1"
                        Content="Encrypt"
                        Width="70"
                        Margin="5,0"                        
                        Command="{Binding EncryptCommand}"/>

                <Button Grid.Column="2"
                        Content="Decrypt"
                        Width="70"
                        Margin="5,0"
                        Command="{Binding DecryptCommand}"/>
            </Grid>
        </Border>

    </Grid>
</Page>
