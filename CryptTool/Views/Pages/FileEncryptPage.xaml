<Page x:Class="CryptTool.Views.Pages.FileEncryptPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CryptTool.Views.Pages"
      xmlns:vm="clr-namespace:CryptTool.ViewModels.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FileEncryptPage" Background="White">

    <Page.DataContext>
        <vm:FileEncryptViewModel/>
    </Page.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- File Path -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="File Path:"/>

            <TextBox Grid.Column="2"
                     Height="26"
                     VerticalContentAlignment="Center"
                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding FilePath}"
                     />

            <Button Grid.Column="4"
                    Height="26"
                    Content="Browse..."
                    Command="{Binding BrowseCommand}"/>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="2"
                    Height="32"
                    Content="Encrypt"
                    Command="{Binding EncryptCommand}"
                    IsEnabled="{Binding CanEncrypt}"/>

            <Button Grid.Column="4"
                    Height="32"
                    Content="Decrypt"
                    Command="{Binding DecryptCommand}"
                    IsEnabled="{Binding CanDecrypt}"/>
        </Grid>

        <!-- Log -->
        <Border Grid.Row="4"
        Padding="10"
        CornerRadius="6"
        BorderThickness="1"
        BorderBrush="#FFBFBFBF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <Button DockPanel.Dock="Right" Width="90" Height="24" Content="Clear" Command="{Binding ClearLogCommand}" HorizontalAlignment="Right" Margin="8,0,0,0"/>
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Log" />
                </DockPanel>

                <ListView Grid.Row="2"
                ItemsSource="{Binding Logs}"
                SelectedItem="{Binding SelectedLog}"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" Width="140"
                               DisplayMemberBinding="{Binding Timestamp}" />
                            <GridViewColumn Header="Level" Width="70"
                               DisplayMemberBinding="{Binding Level}" />
                            <GridViewColumn Header="Message" Width="330"
                               DisplayMemberBinding="{Binding Message}" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <TextBlock Grid.Row="4"
                 Foreground="#FF666666"
                 Text="{Binding SelectedLog.Message}"
                 TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Page>
